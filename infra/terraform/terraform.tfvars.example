# Copy this file to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored — never commit it

# AWS settings
region       = "ap-northeast-2"
instance_type = "t3.large"
aws_profile  = "default"

# Access control — restrict to your IP only (recommended)
# Get your IP: curl https://checkip.amazonaws.com
allowed_cidr = ["YOUR_IP/32"]

# SSH key (leave empty to auto-generate)
key_name = ""

# Secrets — use strong random values
db_password    = "CHANGE_ME_strong_db_password_min16chars"
minio_user     = "yes24minio"
minio_password = "CHANGE_ME_strong_minio_password"
jwt_secret     = "CHANGE_ME_random_32_char_secret_key_here"
