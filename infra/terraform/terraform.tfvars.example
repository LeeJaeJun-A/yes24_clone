# Copy this file to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored — never commit it

# AWS settings
region        = "ap-northeast-2"
instance_type = "t3.large"
aws_profile   = "default"

# SSH key — leave empty (SSH is disabled, use SSM Session Manager instead)
# Connect: aws ssm start-session --target <instance-id>
key_name = ""

# Secrets — use strong random values
db_password    = "CHANGE_ME_strong_db_password_min16chars"
minio_user     = "yes24minio"
minio_password = "CHANGE_ME_strong_minio_password"
